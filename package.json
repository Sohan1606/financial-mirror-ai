{
  "name": "financial-mirror-ai",
  "version": "1.0.0",
  "description": "Financial Mirror AI - Full-stack web app for financial analysis",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server.js",
    "client": "cd client && npm run dev",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "papaparse": "^5.4.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4"
  }
}
